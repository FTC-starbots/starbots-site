# Vercel Blob - token de leitura/escrita (criado ao adicionar Blob Store no projeto Vercel)
# Para desenvolvimento local: copie para .env.local e preencha, ou use `vercel env pull`
BLOB_READ_WRITE_TOKEN=

# Login do dashboard (conta única; não há link no site — acesse pela URL /login)
# SESSION_SECRET: string aleatória longa (gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=
ALLOWED_LOGIN_EMAIL=ftcstarbots@gmail.com
ALLOWED_LOGIN_PASSWORD=
